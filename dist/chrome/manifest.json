{
  "name": "Therp Timer OWL",
  "version": "2.1.0",
  "description": "Therp Timer rewritten with Owl for Odoo timesheet tracking.",
  "manifest_version": 3,
  "icons": {
    "16": "img/icon_16.png",
    "32": "img/icon_32.png",
    "48": "img/icon_48.png",
    "128": "img/icon_128.png"
  },
  "action": {
    "default_icon": {
      "16": "img/inactive_16.png",
      "19": "img/inactive_19.png",
      "32": "img/inactive_32.png",
      "38": "img/inactive_38.png",
      "48": "img/inactive_48.png",
      "128": "img/inactive_128.png"
    },
    "default_title": "Therp Timer OWL",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "js/background.js"
  },
  "options_ui": {
    "page": "options_main_page.html",
    "open_in_tab": true
  },
  "permissions": [
    "storage",
    "cookies"
  ]
}