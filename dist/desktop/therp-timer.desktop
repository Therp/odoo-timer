[Desktop Entry]
Version=1.0
Type=Application
Name=Therp Timer
GenericName=Odoo Time Tracker
Comment=Track and post time to Odoo timesheets
Exec=therp-timer %U
Icon=therp-timer
Terminal=false
StartupNotify=true
StartupWMClass=therp-timer
Categories=Office;ProjectManagement;
Keywords=odoo;timer;timesheet;time;tracking;project;task;
MimeType=x-scheme-handler/therp-timer;
