<?xml version="1.0" encoding="UTF-8"?>
<!--
  messages_app.xml — OWL template for MessagesApp.
  Compile: bash scripts/compile-templates.sh
  NOTE: All expressions are JavaScript, not Python.
-->
<templates xml:space="preserve">

  <t t-name="MessagesApp">
    <div class="messages-layout">

      <!-- Sidebar -->
      <aside class="messages-sidebar" id="tasksPane">
        <div class="messages-search">
          <input id="task-search" placeholder="Search tasks/issues..."
            t-att-value="state.taskSearch"
            t-on-input="(ev) => { state.taskSearch = ev.target.value; }"/>
        </div>
        <div class="task-list">
          <t t-if="state.loading">
            <div class="tasks-empty"><i class="fa fa-cog fa-spin"/> Loading…</div>
          </t>
          <t t-elif="!visibleTasks.length">
            <div class="tasks-empty">No matching tasks or issues.</div>
          </t>
          <t t-foreach="visibleTasks" t-as="task" t-key="task.id">
            <div t-att-class="(state.selectedTask &amp;&amp; task.id === state.selectedTask.id ? 'task-card active' : 'task-card') + ((state.unreadMap[task.id] || 0) > 0 ? ' has-unread ' + (task.followerType === 'follower' ? 'is-follower' : 'is-assigned') : '')"
              t-att-data-task-id="task.id"
              t-on-click="onTaskItemClick">
              <div class="task-title">
                <t t-if="task.followerType === 'follower'">
                  <span class="badge-follower">👁 Following</span>
                </t>
                <t t-else="">
                  <span class="badge-assigned">👤 Assigned</span>
                </t>
                <t t-esc="task.name"/>
              </div>
              <div class="task-meta">
                <span class="task-badge">
                  <i class="fa fa-folder-open-o"/>
                  <t t-esc="normalizeText(task.project_id) || 'No project'"/>
                </span>
                <span><t t-esc="normalizeText(task.stage_id) || ''"/></span>
                <t t-if="(state.unreadMap[task.id] || 0) > 0">
                  <span t-att-class="task.followerType === 'follower' ? 'msg-unread-badge msg-unread-follower' : 'msg-unread-badge msg-unread-assigned'">
                    <t t-esc="state.unreadMap[task.id]"/>
                  </span>
                </t>
              </div>
            </div>
          </t>
        </div>
      </aside>

      <!-- Main pane -->
      <main class="messages-main">

        <!-- Top bar -->
        <div class="messages-topbar">
          <div class="messages-topbar-title">
            <div class="messages-title">Inbox</div>
            <div class="messages-subtitle">
              <t t-esc="totalUnread"/> unread · latest 10 per tracked item
            </div>
          </div>
          <div class="messages-top-actions">
            <button class="messages-btn" t-on-click="toggleShowAll">
              <i class="fa fa-list"/>
              <t t-if="state.showAllTasks">My Tasks</t>
              <t t-else="">All Tasks</t>
            </button>
            <button class="messages-btn" t-on-click="openTaskInBrowser">
              <i class="fa fa-external-link"/> Open in Odoo
            </button>
            <button class="messages-btn" t-on-click="markAllRead">
              <i class="fa fa-check"/> Read all
            </button>
            <button class="messages-btn" t-on-click="refreshMessages">
              <i class="fa fa-refresh"/> Refresh
            </button>
          </div>
        </div>

        <!-- Thread header -->
        <t t-if="state.selectedTask">
          <div class="message-thread-header">
            <div class="message-thread-title">
              <a href="#" t-on-click.prevent="openTaskInBrowser">
                <t t-esc="state.selectedTask.name"/>
              </a>
              <t t-if="state.selectedTask.followerType === 'follower'">
                <span class="badge-follower" style="margin-left:8px;">👁 Following</span>
              </t>
              <t t-else="">
                <span class="badge-assigned" style="margin-left:8px;">👤 Assigned</span>
              </t>
            </div>
            <div class="message-legend">
              <button class="filter-chip" t-att-class="filterAllClass"
                data-filter="all" t-on-click="onFilterClick">
                <span class="dot"/> All
              </button>
              <button class="filter-chip" t-att-class="filterCommentClass"
                data-filter="comment" t-on-click="onFilterClick">
                <span class="dot"/> Comments
              </button>
              <button class="filter-chip" t-att-class="filterNoteClass"
                data-filter="note" t-on-click="onFilterClick">
                <span class="dot"/> Notes
              </button>
            </div>
          </div>
        </t>

        <!-- Message thread -->
        <div class="messages-thread" id="messages-list">
          <t t-if="state.loadingMessages">
            <div style="padding:32px;text-align:center;color:#94a3b8;">
              <i class="fa fa-cog fa-spin fa-2x"/>
            </div>
          </t>
          <t t-elif="!filteredMessages.length &amp;&amp; state.selectedTask">
            <div style="padding:32px;text-align:center;color:#94a3b8;">
              No messages found.
            </div>
          </t>
          <t t-elif="!state.selectedTask">
            <div style="padding:32px;text-align:center;color:#94a3b8;">
              Select a task from the sidebar to view messages.
            </div>
          </t>
          <t t-foreach="filteredMessages" t-as="msg" t-key="msg.id">
            <div t-att-class="'msg-bubble ' + msgClass(msg)">
              <div class="msg-header">
                <span class="msg-author"><t t-esc="authorName(msg)"/></span>
                <span class="msg-time"><t t-esc="timeAgo(msg.date)"/></span>
              </div>
              <div class="msg-body" t-out="bodyMarkup(msg)"/>
              <t t-if="msg.attachment_ids &amp;&amp; msg.attachment_ids.length">
                <div class="msg-attachments">
                  <t t-foreach="msg.attachment_ids" t-as="attId" t-key="attId">
                    <span class="att-chip" t-att-data-att-id="attId"
                      t-on-click="onAttachmentClick">
                      <i class="fa fa-paperclip"/>
                      <t t-esc="getAttachmentName(attId)"/>
                    </span>
                  </t>
                </div>
              </t>
            </div>
          </t>
        </div>

        <!-- Compose box -->
        <t t-if="state.selectedTask">
          <div class="messages-compose">
            <div class="compose-tabs">
              <button t-att-class="composeCommentClass"
                data-compose-type="comment" t-on-click="onComposeTypeClick">
                <i class="fa fa-comment"/> Comment
              </button>
              <button t-att-class="composeNoteClass"
                data-compose-type="note" t-on-click="onComposeTypeClick">
                <i class="fa fa-sticky-note-o"/> Note
              </button>
            </div>
            <div style="position:relative;">
              <textarea id="compose-text"
                t-att-placeholder="composeHint"
                t-att-value="state.composeText"
                t-on-input="handleComposeInput"
                t-on-keydown="handleComposeKeydown"
                rows="3"/>
              <t t-if="state.mentionResults.length">
                <div class="mention-dropdown">
                  <t t-foreach="state.mentionResults" t-as="user" t-key="user.id">
                    <div class="mention-item" t-att-data-user-id="user.id"
                      t-on-click="onMentionClick">
                      <t t-esc="user.name"/>
                    </div>
                  </t>
                </div>
              </t>
            </div>
            <div class="compose-actions">
              <t t-if="state.attachment">
                <span class="att-chip">
                  <i class="fa fa-paperclip"/>
                  <t t-esc="state.attachment.name"/>
                  <i class="fa fa-times" t-on-click="clearAttachment"
                    style="cursor:pointer;margin-left:4px;"/>
                </span>
              </t>
              <button class="messages-btn" t-on-click="pickAttachment">
                <i class="fa fa-paperclip"/> Attach
              </button>
              <button class="messages-btn send-btn"
                t-att-disabled="state.sending" t-on-click="sendMessage">
                <i t-att-class="state.sending ? 'fa fa-cog fa-spin' : 'fa fa-send'"/>
                <t t-if="state.sending">Sending…</t>
                <t t-else="">Send (Ctrl+Enter)</t>
              </button>
            </div>
          </div>
        </t>

      </main>
    </div>
  </t>

</templates>