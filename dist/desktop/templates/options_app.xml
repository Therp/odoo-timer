<?xml version="1.0" encoding="UTF-8"?>
<!--
  options_app.xml — OWL template source for the OptionsApp component.

  Compile with:  bash scripts/compile-templates.sh
  Output:        renderer/js/templates.js  (OptionsApp key)

  Sidebar pages: About | Options | Storage | Security | Help
-->
<templates xml:space="preserve">

  <t t-name="OptionsApp" owl="1">
    <div>
      <!-- ── Sidebar ─────────────────────────────────────── -->
      <div id="navigation">
        <h1 class="title-app">Timer Options</h1>
        <ul class="list-group">
          <li class="chooser list-group-item"
            t-att-class="state.activePage === 'about' ? 'selected' : 'notselected'"
            t-on-click="() => { state.activePage = 'about'; refreshStoragePaths(); }">
            <i class="fa fa-info-circle"/> <span>About Timer</span>
          </li>
          <li class="chooser list-group-item"
            t-att-class="state.activePage === 'options' ? 'selected' : 'notselected'"
            t-on-click="() => { state.activePage = 'options'; }">
            <i class="fa fa-cogs"/> <span>Options</span>
          </li>
          <li class="chooser list-group-item"
            t-att-class="state.activePage === 'storage' ? 'selected' : 'notselected'"
            t-on-click="() => { state.activePage = 'storage'; refreshStoragePaths(); }">
            <i class="fa fa-hdd-o"/> <span>Storage</span>
          </li>
          <li class="chooser list-group-item"
            t-att-class="state.activePage === 'security' ? 'selected' : 'notselected'"
            t-on-click="() => { state.activePage = 'security'; }">
            <i class="fa fa-shield"/> <span>Security</span>
          </li>
          <li class="chooser list-group-item"
            t-att-class="state.activePage === 'help' ? 'selected' : 'notselected'"
            t-on-click="() => { state.activePage = 'help'; }">
            <i class="fa fa-question-circle"/> <span>Help</span>
          </li>
        </ul>
        <hr/>
        <div class="footer-app">
          <a href="popup.html" class="back-left">
            <i class="fa fa-arrow-circle-left fa-2x"/>
          </a>
        </div>
      </div>

      <!-- ── About page ──────────────────────────────────── -->
      <div class="options-box box"
        t-att-class="state.activePage === 'about' ? 'active_page' : 'inactive_page'">
        <h1><div class="logo"><img src="img/logo.png"/></div></h1><hr/>
        <div class="about-app">
          <h4 class="title-app text-center">Description</h4><hr/>
          Therp Timer Desktop is a native Electron application for logging work hours
          directly into Odoo timesheets. It supports tasks and issues, built-in screen
          recording, chatter messaging, and runs silently in the system tray.
          <hr/>
          <h4 class="title-app text-center">Features</h4><hr/>
          <div class="timer-features">
            <ul class="list-group">
              <li class="list-group-item"><i class="fa fa-clock-o"/> Start/stop timer — creates Odoo timesheet lines automatically</li>
              <li class="list-group-item"><i class="fa fa-tasks"/> Supports project.task and project.issue data sources</li>
              <li class="list-group-item"><i class="fa fa-video-camera"/> Screen recorder — WebM, MP4, MKV formats</li>
              <li class="list-group-item"><i class="fa fa-microphone"/> Audio recording — microphone or system audio</li>
              <li class="list-group-item"><i class="fa fa-camera"/> Screenshot tool with configurable save folder</li>
              <li class="list-group-item"><i class="fa fa-film"/> Animated GIF capture</li>
              <li class="list-group-item"><i class="fa fa-comments"/> Chatter — read and post task messages, @mentions, attachments</li>
              <li class="list-group-item"><i class="fa fa-bell"/> Desktop notifications for new chatter messages</li>
              <li class="list-group-item"><i class="fa fa-table"/> Task timesheets window with planned vs. spent summary</li>
              <li class="list-group-item"><i class="fa fa-download"/> Download monthly timesheet as CSV</li>
              <li class="list-group-item"><i class="fa fa-exchange"/> Multi-remote support — switch between Odoo instances</li>
              <li class="list-group-item"><i class="fa fa-database"/> Config backup and restore (import/export JSON)</li>
              <li class="list-group-item"><i class="fa fa-desktop"/> Runs in the system tray — keeps timing in the background</li>
            </ul>
          </div>
          <h4 class="title-app text-center" style="margin-top:16px;">Packages</h4><hr/>
          <div class="timer-features">
            <ul class="list-group">
              <li class="list-group-item"><b>electron</b> ^29.4.6 — Desktop app framework</li>
              <li class="list-group-item"><b>electron-builder</b> ^24.13.3 — Cross-platform packaging</li>
              <li class="list-group-item"><b>electron-store</b> ^8.1.0 — Persistent key-value storage</li>
              <li class="list-group-item"><b>owl</b> 2.x — Odoo Web Library UI framework (renderer)</li>
              <li class="list-group-item"><b>font-awesome</b> 4.6.3 — Icon set</li>
              <li class="list-group-item"><b>eslint</b> ^8.57.0 — JavaScript linter</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- ── Options / remote form ──────────────────────── -->
      <div class="options-box box"
        t-att-class="state.activePage === 'options' ? 'active_page' : 'inactive_page'">
        <div class="form remote-options-form">
          <form t-on-submit.prevent="addRemote">
            <h4 class="remote-title text-info">Add Remote</h4><hr/>
            <div class="form-group">
              <label for="remote-host">Odoo Host</label>
              <input type="text" class="form-control" id="remote-host"
                placeholder="https://your-odoo-host.example"
                t-model="state.form.remote_host"/>
            </div>
            <div class="form-group">
              <label for="remote-name">Display Name</label>
              <input type="text" class="form-control" id="remote-name"
                placeholder="My Odoo"
                t-model="state.form.remote_name"/>
            </div>
            <div class="form-group">
              <label for="remote-database">Odoo Database</label>
              <input type="text" class="form-control" id="remote-database"
                placeholder="myodoodatabase"
                t-model="state.form.remote_database"/>
            </div>
            <div class="form-group">
              <label for="remote-odoo-version">Odoo Version <span class="text-muted">(e.g. 16.0)</span></label>
              <input type="text" class="form-control" id="remote-odoo-version"
                placeholder="16.0"
                t-model="state.form.remote_odoo_version"/>
            </div>
            <div class="form-group">
              <label for="remote-poll">Message Poll Interval <span class="text-muted">(seconds, 0 = off)</span></label>
              <input type="number" class="form-control" id="remote-poll"
                placeholder="60" min="0"
                t-model="state.form.remote_poll_interval"/>
            </div>
            <div class="form-group">
              <label class="label">Data Source</label>
              <ul class="data-source-list list-group">
                <li class="list-group-item">
                  <div class="form-check">
                    <input class="form-check-input" type="radio"
                      value="project.issue" id="FromIssues"
                      t-att-checked="state.form.remote_datasrc === 'project.issue'"
                      t-on-change="(ev) => { if (ev.target.checked) state.form.remote_datasrc = 'project.issue'; }"/>
                    <label class="form-check-label" for="FromIssues">From Issues</label>
                  </div>
                </li>
                <li class="list-group-item">
                  <div class="form-check">
                    <input class="form-check-input" type="radio"
                      value="project.task" id="FromTasks"
                      t-att-checked="state.form.remote_datasrc === 'project.task'"
                      t-on-change="(ev) => { if (ev.target.checked) state.form.remote_datasrc = 'project.task'; }"/>
                    <label class="form-check-label" for="FromTasks">From Tasks</label>
                  </div>
                </li>
              </ul>
            </div>
            <span class="caption-remotes">Controls</span>
            <div class="remotes-control-btns col-md-12 text-center text-info pointer">
              <i title="Add a remote host" class="fa fa-2x fa-plus-circle" t-on-click="addRemote"/>
              <i title="Refresh list of remotes" class="fa fa-2x fa-refresh" t-on-click="loadRemotes"/>
              <i title="View list of remotes" class="fa fa-2x fa-eye" t-on-click="() => { state.showList = !state.showList; }"/>
              <i title="Remove all remotes" class="fa fa-2x fa-minus-circle" t-on-click="removeAllRemotes"/>
            </div>
            <t t-if="state.error">
              <div class="remote-error"><t t-esc="state.error"/></div>
            </t>
          </form>

          <!-- Remotes table -->
          <t t-if="state.showList and state.remotes.length">
            <div class="remotes-table-info">
              <table class="table table-bordered">
                <caption class="text-info caption-remotes">List of Available Remotes</caption>
                <thead>
                  <tr>
                    <th>Remote</th>
                    <th>Host</th>
                    <th>Database</th>
                    <th>Version</th>
                    <th>Poll (s)</th>
                    <th>Source</th>
                    <th>State</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody>
                  <t t-foreach="state.remotes" t-as="remote" t-key="remote.url + remote.database">
                    <tr>
                      <td class="text-info">
                        <ReadMore text="remote.name || ''" limit="18"/>
                      </td>
                      <td>
                        <ReadMore text="remote.url || ''" limit="28"/>
                      </td>
                      <td>
                        <ReadMore text="remote.database || ''" limit="18"/>
                      </td>
                      <td>
                        <ReadMore text="remote.odooVersion || '—'" limit="10"/>
                      </td>
                      <td>
                        <ReadMore text="String(remote.pollInterval !== undefined && remote.pollInterval !== null ? remote.pollInterval : 60)" limit="6"/>
                      </td>
                      <td>
                        <ReadMore text="remote.datasrc || 'project.issue'" limit="18"/>
                      </td>
                      <td>
                        <ReadMore text="remote.state || 'Inactive'" limit="12"/>
                      </td>
                      <td class="remote-row-actions">
                        <i class="fa fa-pencil text-info" title="Edit remote" t-on-click="() => editRemote(remote)"/>
                        <i class="fa fa-trash text-danger" title="Remove remote" t-on-click="() => removeRemote(remote)"/>
                      </td>
                    </tr>
                  </t>
                </tbody>
              </table>
            </div>
          </t>
        </div>
      </div>

      <!-- ── Storage page ────────────────────────────────── -->
      <div class="options-box box"
        t-att-class="state.activePage === 'storage' ? 'active_page' : 'inactive_page'">
        <h4 class="title-app"><i class="fa fa-hdd-o"/> Storage Preferences</h4><hr/>
        <div class="about-app">
          <p class="text-muted" style="font-size:13px;">
            Set persistent save folders for recordings and screenshots.
            When configured, the save dialog is skipped and files go directly to the folder.
          </p>
          <div class="form-group">
            <label>Screenshot Save Folder</label>
            <div class="folder-row">
              <span class="folder-path-display" id="ss-folder-display">
                <t t-esc="state.screenshotFolder || 'Not set (will prompt)'"/>
              </span>
              <button class="btn btn-sm btn-default" t-on-click="pickScreenshotFolder">Browse…</button>
              <button class="btn btn-sm btn-danger" t-on-click="clearScreenshotFolder">Clear</button>
            </div>
          </div>
          <div class="form-group" style="margin-top:12px;">
            <label>Video / GIF Save Folder</label>
            <div class="folder-row">
              <span class="folder-path-display" id="vid-folder-display">
                <t t-esc="state.videoFolder || 'Not set (will prompt)'"/>
              </span>
              <button class="btn btn-sm btn-default" t-on-click="pickVideoFolder">Browse…</button>
              <button class="btn btn-sm btn-danger" t-on-click="clearVideoFolder">Clear</button>
            </div>
          </div>
          <hr/>
          <h4 class="title-app"><i class="fa fa-database"/> Backup &amp; Restore</h4>
          <p class="text-muted" style="font-size:13px;">
            Export all configuration (remotes, preferences) to a JSON file,
            or import a previous backup.
          </p>
          <div style="display:flex;gap:10px;">
            <button class="btn btn-default" t-on-click="exportConfig">
              <i class="fa fa-download"/> Export Config
            </button>
            <button class="btn btn-default" t-on-click="importConfig">
              <i class="fa fa-upload"/> Import Config
            </button>
          </div>
        </div>
      </div>

      <!-- ── Security page ───────────────────────────────── -->
      <div class="options-box box"
        t-att-class="state.activePage === 'security' ? 'active_page' : 'inactive_page'">
        <h4 class="title-app"><i class="fa fa-shield"/> Security &amp; Sandbox</h4><hr/>
        <div class="about-app">
          <h5>Linux AppImage — Sandbox</h5>
          <p class="text-muted" style="font-size:13px;">
            On Linux, the AppImage SUID sandbox helper may not be set up correctly.
            The app automatically applies <code>--no-sandbox</code> to remain functional.
            To restore full Chromium sandboxing, run one of the following:
          </p>
          <ul class="list-group">
            <li class="list-group-item">
              <code>sudo chown root /tmp/.mount_Therp-*/chrome-sandbox &amp;&amp; sudo chmod 4755 /tmp/.mount_Therp-*/chrome-sandbox</code>
            </li>
            <li class="list-group-item">
              Or launch with: <code>./Therp-Timer.AppImage --no-sandbox</code>
            </li>
          </ul>
          <h5 style="margin-top:16px;">Session Cookies</h5>
          <p class="text-muted" style="font-size:13px;">
            Odoo session cookies are stored in the Electron Chromium session and are
            cleared on logout. No passwords are stored in plain text.
          </p>
          <h5 style="margin-top:16px;">Local Data Storage</h5>
          <p class="text-muted" style="font-size:13px;">
            All settings are stored via <b>electron-store</b> in the OS user-data
            directory. No data is sent to third parties.
          </p>
        </div>
      </div>

      <!-- ── Help / Tutorial page ───────────────────────── -->
      <div class="options-box box"
        t-att-class="state.activePage === 'help' ? 'active_page' : 'inactive_page'">
        <h4 class="title-app"><i class="fa fa-question-circle"/> Help &amp; Tutorial</h4><hr/>
        <div class="about-app">
          <h5>Getting Started</h5>
          <ol class="list-group">
            <li class="list-group-item">Go to <b>Options → Options</b> and click <i class="fa fa-plus-circle"/> to add an Odoo remote host.</li>
            <li class="list-group-item">Return to the Timer window. Choose your remote from the dropdown on the login screen.</li>
            <li class="list-group-item">Enable <em>Use Existing Session</em> if already logged into Odoo in the browser, or enter your credentials.</li>
            <li class="list-group-item">Click <i class="fa fa-play-circle"/> next to any task or issue row to start timing.</li>
            <li class="list-group-item">Click <i class="fa fa-stop-circle text-danger"/> to stop — time is posted to Odoo timesheets automatically.</li>
          </ol>
          <h5 style="margin-top:16px;">Toolbar Buttons</h5>
          <ul class="list-group">
            <li class="list-group-item"><i class="fa fa-download"/> — Download current month timesheets as CSV</li>
            <li class="list-group-item"><i class="fa fa-hand-o-left"/> — Switch between configured remotes</li>
            <li class="list-group-item"><i class="fa fa-refresh"/> — Refresh task/issue list from Odoo</li>
            <li class="list-group-item"><i class="fa fa-clock-o"/> — Discard active timer (no time recorded)</li>
            <li class="list-group-item"><i class="fa fa-sign-out"/> — Log out from current remote</li>
            <li class="list-group-item"><i class="fa fa-comments"/> — Open Messages / chatter window</li>
            <li class="list-group-item"><i class="fa fa-video-camera"/> — Open screen recorder (video, GIF, screenshot)</li>
            <li class="list-group-item"><i class="fa fa-list-alt"/> — View task timesheets window (task mode only)</li>
            <li class="list-group-item"><i class="fa fa-bug"/> — View internal application logs</li>
          </ul>
          <h5 style="margin-top:16px;">Keyboard Shortcuts</h5>
          <ul class="list-group">
            <li class="list-group-item"><kbd>Ctrl+Enter</kbd> — Send message in chatter compose box</li>
            <li class="list-group-item"><kbd>Escape</kbd> — Close @mention dropdown in chatter</li>
          </ul>
          <h5 style="margin-top:16px;">System Tray</h5>
          <p class="text-muted" style="font-size:13px;">
            Right-click the system tray icon to access Timer, Messages, Recorder,
            Screenshot (quick capture), Options, Logs and Quit.
            Closing the main window keeps the app running in the tray.
            The icon becomes active (coloured) when a timer or recording is running.
          </p>
          <h5 style="margin-top:16px;">Screen Recorder Tips</h5>
          <ul class="list-group">
            <li class="list-group-item">Use <b>Region</b> source to draw a selection area on screen.</li>
            <li class="list-group-item">Set <b>Auto-stop after</b> to cap recording length automatically.</li>
            <li class="list-group-item">Choose <b>MP4</b> format for the widest video player compatibility.</li>
            <li class="list-group-item">Choose <b>System</b> audio to capture speaker output (Windows).</li>
            <li class="list-group-item">Configure save folders in <b>Storage</b> to skip the dialog every time.</li>
          </ul>
        </div>
      </div>

    </div>
  </t>

</templates>