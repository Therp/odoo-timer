{
  "name": "Therp Timer OWL",
  "version": "2.0.1",
  "description": "Therp Timer rewritten with Owl for Odoo timesheet tracking.",
  "manifest_version": 3,
  "icons": {
    "16": "img/icon_16.png",
    "48": "img/icon_48.png",
    "128": "img/icon_128.png"
  },
  "action": {
    "default_icon": {
      "16": "img/inactive_16.png",
      "19": "img/inactive_19.png",
      "38": "img/inactive_38.png"
    },
    "default_title": "Therp Timer OWL",
    "default_popup": "popup.html"
  },
  "background": {
    "scripts": ["js/background.js"],
    "type": "module"
  },
  "options_ui": {
    "page": "options_main_page.html",
    "open_in_tab": true
  },
  "permissions": [
    "storage",
    "cookies",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}