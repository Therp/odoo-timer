<templates xml:space="preserve">
  <t t-name="PopupApp" owl="1">
    <div class="app-root">
      <div
        id="loader-container"
        t-att-class="state.view === 'loading' ? '' : 'hide'"
      >
        <div class="loader-card">
          <div class="loader-text">
            Loading current session and projects…
          </div>
          <div class="loader-subtext">
            Please wait — or grab a cup of coffee ☕
          </div>
          <i class="fa fa-cog fa-spin fa-5x"/>
        </div>
      </div>

      <div
        id="login"
        class="login-view"
        t-att-class="state.view === 'login' ? 'login-view' : 'login-view hide'"
      >
        <div class="popup-login-shell">
          <div class="form">
            <div class="logo">
              <img src="/img/logo.png"/>
            </div>

            <t t-if="state.bootError">
              <div>
                <p class="odooError" t-out="state.bootError"/>
              </div>
            </t>

            <t t-if="!state.remotes.length">
              <div class="container no-remotes-set">
                <div class="alert alert-warning">
                  Hello <span class="fun-man">😉</span>, you have not configured
                  any remotes. Open
                  <b><i class="fa fa-cogs"/> Options</b>
                  below and add one.
                </div>
              </div>
            </t>

            <t t-if="state.remotes.length">
              <form t-on-submit.prevent="login">
                <t t-if="state.loginError">
                  <p class="odooError" t-out="state.loginError"/>
                </t>

                <t t-if="!state.useExistingSession">
                  <input
                    type="text"
                    placeholder="Username"
                    t-att-value="state.username"
                    t-on-input="(ev) => state.username = ev.target.value"
                  />
                </t>

                <div class="password-field">
                  <t t-if="!state.useExistingSession">
                    <input
                      id="unique-password"
                      t-att-type="state.showPassword ? 'text' : 'password'"
                      placeholder="Password"
                      t-att-value="state.password"
                      t-on-input="(ev) => state.password = ev.target.value"
                    />
                  </t>

                  <t t-if="!state.useExistingSession">
                    <span
                      class="pass-viewer"
                      t-on-click="togglePassword"
                    >
                      <i
                        class="fa"
                        t-att-class="state.showPassword ? 'fa fa-eye-slash' : 'fa fa-eye'"
                      />
                    </span>
                  </t>
                </div>

                <select
                  id="remote-selection"
                  class="form-control"
                  t-on-change="(ev) => state.selectedRemoteIndex = ev.target.value"
                >
                  <t
                    t-foreach="state.remotes"
                    t-as="remote"
                    t-key="remote.database + remote.url"
                  >
                    <option
                      t-att-value="remote.__index"
                      t-att-selected="state.selectedRemoteIndex === remote.__index"
                      t-out="remote.name"
                    />
                  </t>
                </select>

                <div class="checkbox">
                  <label>
                    <input
                      type="checkbox"
                      t-att-checked="state.useExistingSession"
                      t-on-change="toggleUseExistingSession"
                    />
                    Use Existing Session
                  </label>
                </div>

                <button class="login" type="submit">
                  Login
                  <t t-if="state.loginLoading">
                    <i class="fa fa-cog fa-spin"/>
                  </t>
                </button>

                <t t-if="currentRemote">
                  <div class="remote-info small-note">
                    Host:
                    <t t-out="currentRemote.url"/>
                    <span class="current-source-chip">
                      <t t-out="currentRemote.datasrc || 'project.issue'"/>
                    </span>
                  </div>
                </t>
              </form>
            </t>
          </div>
        </div>

        <div class="cta forgotpwd footer-app-opts login-footer-bar">
          <a href="options_main_page.html">
            <i class="fa fa-cogs"/> Options
          </a>
        </div>
      </div>

      <div
        id="wrapper"
        t-att-class="state.view === 'main' ? '' : 'hide'"
      >
        <div class="toolbar-row">
          <input
            id="searchIssue"
            type="text"
            placeholder="Search by ID, name, user, priority, stage..."
            t-att-value="state.searchQuery"
            t-on-input="(ev) => state.searchQuery = ev.target.value"
          />
          <select
            id="limitTo"
            t-model="state.limitTo"
            t-on-change="(ev) => updateLimitPreference(ev.target.value)"
          >
            <option value="10">10</option>
            <option value="15">15</option>
            <option value="25">25</option>
            <option value="">All</option>
          </select>
        </div>

        <div class="container footer top-actions">
          <div class="row">
            <div class="mx-3 col-md-12 footer-btns pointer">
              <i
                class="fa fa-download fa-2x"
                title="Download current month timesheet"
                t-on-click="downloadCurrentMonthTimesheets"
              />
              <i
                class="fa fa-hand-o-left fa-2x"
                title="Switch between remotes"
                t-on-click="switchBetweenRemotes"
              />
              <i
                class="fa fa-refresh fa-2x"
                title="Refresh current items"
                t-on-click="refreshAll"
              />
              <i
                class="fa fa-clock-o fa-2x"
                title="Discard the active timer"
                t-on-click="resetTimer"
              />
              <i
                class="fa fa-sign-out fa-2x"
                title="Log out"
                t-on-click="logout"
              />
              <a
                href="options_main_page.html"
                class="options-btn"
                title="Go To options"
              >
                <i class="fa fa-cogs fa-2x"/>
              </a>
            </div>
          </div>
        </div>

        <div class="table-scroll">
          <table
            id="table-task-issues"
            class="table table-responsive-sm table-bordered table-fixed"
          >
            <thead>
              <tr>
                <th class="action-col">
                  <div/>

                  <t t-if="state.timerStartIso">
                    <span class="startTimeCount" t-out="formattedTimer"/>
                  </t>
                </th>

                <th class="priority-col">Priority</th>
                <th class="stage-col">Stage</th>

                <th class="item-col">
                  <div class="item-header-title">
                    <t t-out="itemLabelPlural"/> [<t t-out="filteredIssues.length"/>]
                  </div>
                  <label class="allIssues">
                    <input
                      id="showAllIssues"
                      type="checkbox"
                      t-att-checked="state.allIssues"
                      t-on-input="(ev) => updateShowAllPreference(ev.target.checked)"
                    />
                    Show for everyone
                  </label>
                </th>

                <t t-if="state.dataSource === 'project.task'">
                  <th class="text-center">Hours Spent</th>
                  <th class="text-center">Hours Left</th>
                </t>

                <th class="project-col">Project</th>
              </tr>
            </thead>

            <tbody>
              <t t-if="filteredIssues.length">
                <t
                  t-foreach="filteredIssues"
                  t-as="issue"
                  t-key="issue.id"
                >
                  <tr
                    t-att-class="state.activeTimerId === issue.id ? 'active-row' : ''"
                  >
                    <td class="text-center px-2 td-btn action-col">
                      <t t-if="!state.activeTimerId">
                        <i
                          class="fa fa-play-circle action-btn pointer"
                          title="Start the timer for the selected item"
                          t-on-click="() => startTimer(issue)"
                        />
                      </t>

                      <t t-if="state.activeTimerId === issue.id">
                        <i
                          class="text-danger fa fa-stop-circle action-btn pointer"
                          title="Stop timer and record the time to Odoo timesheets"
                          t-on-click="() => stopTimer(issue)"
                        />
                      </t>
                    </td>

                    <td class="priority-cell">
                      <t t-if="issue.priority_level.length">
                        <t
                          t-foreach="issue.priority_level"
                          t-as="priority"
                          t-key="priority + '_' + issue.id"
                        >
                          <span class="fa fa-star checked"/>
                        </t>
                      </t>
                      <t t-if="!issue.priority_level.length">
                        <i class="fa fa-star-o"/>
                      </t>
                    </td>

                    <td class="stage-cell">
                      <ReadMore
                        text="relationLabel(issue.stage_id)"
                        limit="15"
                      />
                    </td>

                    <td class="issue-desc-cell">
                      <ReadMore
                        text="issueLabel(issue)"
                        limit="70"
                        href="issueHref(issue)"
                      />
                    </td>

                    <t t-if="state.dataSource === 'project.task'">
                      <td class="text-center">
                        <ReadMore
                          text="normalizeText(formatHours(issue.effective_hours))"
                          limit="9"
                        />
                      </td>
                      <td class="text-center">
                        <ReadMore
                          text="normalizeText(formatHours(issue.remaining_hours))"
                          limit="9"
                        />
                      </td>
                    </t>

                    <td class="project-cell">
                      <ReadMore
                        text="relationLabel(issue.project_id)"
                        limit="15"
                      />
                    </td>
                  </tr>
                </t>
              </t>

              <t t-if="!filteredIssues.length">
                <tr>
                  <td
                    class="text-center text-danger"
                    t-att-colspan="state.dataSource === 'project.task' ? 7 : 5"
                  >
                    No matching items are currently available
                  </td>
                </tr>
              </t>
            </tbody>
          </table>
        </div>

        <div class="container footer info-footer">
          <div class="row">
            <div class="remote-info-block col-md-12">
              <span><b>Odoo:</b> <span class="remote-value" t-out="state.serverVersion || 'Unknown'"/></span><br/>
              <span><b>OWL:</b> <span class="remote-value" t-out="state.odooOWLVersion || 'Unknown'"/></span><br/>
              <span><b>Host:</b> <span class="remote-value" t-out="state.currentHost || '-'"/></span><br/>
              <span><b>Database:</b> <span class="remote-value" t-out="state.currentDatabase || '-'"/></span><br/>
              <span><b>Current User:</b> <span class="remote-value" t-out="state.user ? state.user.display_name : '-'"/></span><br/>
            </div>
          </div>
        </div>
      </div>
    </div>
  </t>
</templates>