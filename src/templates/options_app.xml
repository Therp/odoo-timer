<templates xml:space="preserve">
  <t t-name="OptionsApp" owl="1">
    <div>

      <!-- ── Left navigation sidebar ─────────────────────────────────── -->
      <div id="navigation">
        <h1 class="title-app">Timer Options</h1>
        <ul class="list-group">
          <li
            class="chooser list-group-item"
            t-att-class="state.activePage === 'about' ? 'selected' : 'notselected'"
            t-on-click="() => state.activePage = 'about'"
          >
            <i class="fa fa-info-circle"/> <span>About Timer</span>
          </li>
          <li
            class="chooser list-group-item"
            t-att-class="state.activePage === 'options' ? 'selected' : 'notselected'"
            t-on-click="() => state.activePage = 'options'"
          >
            <i class="fa fa-cogs"/> <span>Options</span>
          </li>
        </ul>
        <hr/>
        <div class="footer-app">
          <a href="popup.html" class="back-left">
            <i class="fa fa-arrow-circle-left fa-2x"/>
          </a>
        </div>
      </div>

      <!-- ── About page ──────────────────────────────────────────────── -->
      <div
        class="options-box box"
        t-att-class="state.activePage === 'about' ? 'active_page' : 'inactive_page'"
      >
        <h1>
          <div class="logo">
            <img src="/img/logo.png"/>
          </div>
        </h1>
        <hr/>
        <div class="about-app">
          <h4 class="title-app text-center">Description</h4>
          <hr/>
          This is a standalone Owl rewrite of the original cross-platform timer
          extension for posting work hours to Odoo timesheets.
          <hr/>
          <h4 class="title-app text-center">Features</h4>
          <hr/>
          <div class="timer-features">
            <ul class="list-group">
              <li class="list-group-item">Support for both tasks and issues</li>
              <li class="list-group-item">Start and stop the timer for the selected item</li>
              <li class="list-group-item">Create Odoo timesheet lines against the linked analytic account</li>
              <li class="list-group-item">Show assigned items or everyone's items</li>
              <li class="list-group-item">Add, remove, or clear remote hosts</li>
              <li class="list-group-item">Switch between remote sessions</li>
              <li class="list-group-item">Download current month or current item timesheets as CSV</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- ── Options / remotes page ──────────────────────────────────── -->
      <div
        class="options-box box"
        t-att-class="state.activePage === 'options' ? 'active_page' : 'inactive_page'"
      >
        <div class="form remote-options-form">
          <form t-on-submit.prevent="addRemote">

            <!-- [FIX #38] General Settings ──────────────────────────── -->
            <h4 class="remote-title text-info">General Settings</h4>
            <hr/>
            <div class="form-group">
              <label class="general-setting-label">
                <input
                  type="checkbox"
                  class="defaultCheckbox"
                  t-att-checked="state.autoDownloadIssueTimesheet"
                  t-on-change="toggleAutoDownload"
                />
                Auto Download Current Item Timesheet
              </label>
              <p class="inline-help">
                Store timesheet locally each time you stop the timer on an item.
              </p>
            </div>
            <hr/>

            <!-- Add Remote form ─────────────────────────────────────── -->
            <h4 class="remote-title text-info">Add Remote</h4>
            <hr/>

            <div class="form-group">
              <label for="remote-host">Odoo Host</label>
              <input
                type="text"
                class="form-control"
                id="remote-host"
                placeholder="https://your-odoo-host.example"
                t-att-value="state.form.remote_host"
                t-on-input="(ev) => state.form.remote_host = ev.target.value"
              />
            </div>

            <div class="form-group">
              <label for="remote-name">Display Name</label>
              <input
                type="text"
                class="form-control"
                id="remote-name"
                placeholder="Therp"
                t-att-value="state.form.remote_name"
                t-on-input="(ev) => state.form.remote_name = ev.target.value"
              />
            </div>

            <div class="form-group">
              <label for="remote-database">Odoo Database</label>
              <input
                type="text"
                class="form-control"
                id="remote-database"
                placeholder="someodoodatabase"
                t-att-value="state.form.remote_database"
                t-on-input="(ev) => state.form.remote_database = ev.target.value"
              />
            </div>

            <div class="form-group">
              <label class="label">Data Source</label>
              <ul class="data-source-list list-group">
                <li class="list-group-item">
                  <div class="form-check">
                    <input
                      class="form-check-input"
                      type="radio"
                      value="project.issue"
                      id="FromIssues"
                      t-att-checked="state.form.remote_datasrc === 'project.issue'"
                      t-on-change="() => state.form.remote_datasrc = 'project.issue'"
                    />
                    <label class="form-check-label" for="FromIssues">From Issues</label>
                  </div>
                </li>
                <li class="list-group-item">
                  <div class="form-check">
                    <input
                      class="form-check-input"
                      type="radio"
                      value="project.task"
                      id="FromTasks"
                      t-att-checked="state.form.remote_datasrc === 'project.task'"
                      t-on-change="() => state.form.remote_datasrc = 'project.task'"
                    />
                    <label class="form-check-label" for="FromTasks">From Tasks</label>
                  </div>
                </li>
              </ul>
            </div>

            <span class="caption-remotes">Controls</span>
            <div class="remotes-control-btns col-md-12 text-center text-info pointer">
              <i
                title="Add a remote host"
                class="fa fa-2x fa-plus-circle"
                t-on-click="addRemote"
              />
              <i
                title="Refresh list of remotes"
                class="fa fa-2x fa-refresh"
                t-on-click="loadRemotes"
              />
              <i
                title="View list of remotes"
                class="fa fa-2x fa-eye"
                t-on-click="() => state.showList = !state.showList"
              />
              <i
                title="Remove all remotes"
                class="fa fa-2x fa-minus-circle"
                t-on-click="removeAllRemotes"
              />
            </div>

            <t t-if="state.error">
              <div class="remote-error" t-out="state.error"/>
            </t>

          </form>

          <!-- Saved remotes table ──────────────────────────────────── -->
          <t t-if="state.showList and state.remotes.length">
            <div class="remotes-table-info">
              <table class="table table-bordered">
                <caption class="text-info caption-remotes">
                  List of Available Remotes
                </caption>
                <thead>
                  <tr>
                    <th scope="col">Remote</th>
                    <th scope="col">Host</th>
                    <th scope="col">Database</th>
                    <th scope="col">Source</th>
                    <th scope="col">State</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody>
                  <t
                    t-foreach="state.remotes"
                    t-as="remote"
                    t-key="remote.url + remote.database"
                  >
                    <tr>
                      <td class="text-info">
                        <ReadMore text="remote.name" limit="18"/>
                      </td>
                      <td>
                        <ReadMore text="remote.url" limit="25"/>
                      </td>
                      <td>
                        <ReadMore text="remote.database" limit="18"/>
                      </td>
                      <td>
                        <ReadMore text="remote.datasrc || 'project.issue'" limit="18"/>
                      </td>
                      <td>
                        <ReadMore text="remote.state || 'Inactive'" limit="18"/>
                      </td>
                      <td class="remote-row-actions">
                        <i
                          class="fa fa-pencil text-primary"
                          title="Edit remote"
                          t-on-click="() => editRemote(remote)"
                          style="margin-right: 10px; cursor: pointer;"
                        />
                        <i
                          class="fa fa-trash text-danger"
                          title="Remove remote"
                          t-on-click="() => removeRemote(remote)"
                          style="cursor: pointer;"
                        />
                      </td>
                    </tr>
                  </t>
                </tbody>
              </table>
            </div>
          </t>

        </div>
      </div>

    </div>
  </t>
</templates>
